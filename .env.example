# WorthyHire Environment Configuration

# Embedding model (default: BAAI/bge-small-en-v1.5)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranker model (default: cross-encoder/ms-marco-MiniLM-L-6-v2)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Output top N candidates
OUTPUT_TOP_N=100

# API host and port
API_HOST=0.0.0.0
API_PORT=8000
